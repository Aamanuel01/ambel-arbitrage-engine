# ── Blockchain RPC ──────────────────────────────────────────────────────────────
# Polygon mainnet WebSocket endpoint (Alchemy or Infura recommended)
POLYGON_WS_RPC_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Contract Addresses (Polygon Mainnet) ────────────────────────────────────────
AAVE_V3_POOL_ADDRESS=0x794a61358D6845594F94dc1DB02A252b5b4814aD
UNISWAP_V3_FACTORY=0x1F98431c8aD98523631AE4a59f267346ea31F984
SUSHI_FACTORY=0xc35DADB65012eC5796536bD9864eD8773aBc74C4

# ── Bot Parameters ───────────────────────────────────────────────────────────────
# Minimum net profit in USD required before triggering a simulation/alert
MIN_PROFIT_USD=5.0
# Flash loan amount in USD (used for opportunity sizing calculations)
FLASH_LOAN_AMOUNT_USD=50000
# Slippage tolerance (fraction, e.g. 0.005 = 0.5%)
SLIPPAGE=0.005

# ── Gemini AI ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Notifications — set at least one ────────────────────────────────────────────
# Discord webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
# — OR — Telegram bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Wallet (simulation / deployment only — NEVER fund this on mainnet) ───────────
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here

# ── The Graph ────────────────────────────────────────────────────────────────────
THE_GRAPH_API_KEY=your_the_graph_api_key_here
